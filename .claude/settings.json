{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude && jq -r '\"\\(.tool_input.command)\"' >> .claude/bash-log.txt"
          }
        ]
      }
    ]
  }
}

